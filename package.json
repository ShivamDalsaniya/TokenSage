{
  "name": "token-sage",
  "version": "1.0.1",
  "description": "MCP server that reduces LLM token usage by 50%+ while preserving coding accuracy",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "token-sage": "./dist/server/index.js",
    "tokensage": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && rm -rf dist/public && mkdir -p dist/public && cp src/public/tokensage-logo.webp dist/public/",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "node dist/server/index.js",
    "start:dashboard": "node dist/server/dashboard.js",
    "start:daemon": "node dist/daemon/index.js",
    "daemon": "node dist/daemon/index.js",
    "dev": "tsx src/server/index.ts",
    "lint": "eslint src tests --ext .ts --max-warnings 0",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "benchmark": "tsx scripts/benchmark.ts"
  },
  "keywords": [
    "mcp",
    "token",
    "compression",
    "ai",
    "llm",
    "context",
    "optimization"
  ],
  "author": "TokenSage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShivamDalsaniya/TokenSage.git"
  },
  "homepage": "https://github.com/ShivamDalsaniya/TokenSage#readme",
  "bugs": {
    "url": "https://github.com/ShivamDalsaniya/TokenSage/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "assets"
  ],
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "fastify": "^5.4.0",
    "glob": "^11.0.1",
    "gpt-tokenizer": "^2.9.0",
    "ignore": "^6.0.2",
    "minimatch": "^10.0.1",
    "pino": "^9.6.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitest/coverage-v8": "^3.2.3",
    "eslint": "^9.28.0",
    "globals": "^17.6.0",
    "pdfkit": "^0.19.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
